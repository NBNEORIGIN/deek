FROM python:3.12-slim

WORKDIR /app

# System deps for psycopg2
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

# Install only what the API needs (no GPU deps)
RUN pip install --no-cache-dir \
    fastapi>=0.111.0 \
    "uvicorn[standard]>=0.30.0" \
    anthropic>=0.28.0 \
    openai>=1.35.0 \
    pgvector>=0.3.2 \
    psycopg2-binary>=2.9.9 \
    sqlalchemy>=2.0.30 \
    tiktoken>=0.7.0 \
    httpx>=0.27.0 \
    python-dotenv>=1.0.1 \
    rich>=13.7.1 \
    "pydantic>=2.7.0" \
    watchdog>=4.0.0 \
    rank-bm25>=0.2.2 \
    pyyaml>=6.0.1 \
    mcp>=1.0.0 \
    openpyxl>=3.1.0

# Copy application code
COPY api/ ./api/
COPY core/ ./core/
COPY projects/ ./projects/
COPY wiki/ ./wiki/
COPY scripts/ ./scripts/
COPY deploy/modules.json ./deploy/modules.json
# Create data dir
RUN mkdir -p ./data

EXPOSE 8765

CMD ["python", "-m", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8765"]

{
  "name": "Phloe Platform",
  "description": "Multi-tenant Workflow as a Service platform for UK SMBs",
  "codebase_path": "C:/path/to/phloe/repo",
  "project_type": "coding",

  "permissions": [
    "read_file",
    "search_code",
    "run_tests",
    "edit_file",
    "create_file",
    "run_migration"
  ],

  "model_preferences": {
    "force_model": null,
    "prefer_local_for": ["fix", "add", "update", "test", "migration"],
    "prefer_api_for": ["architect", "review", "security", "design"]
  },

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": ["node_modules", "migrations", ".next", "dist"],
    "include_extensions": []
  }
}

{
  "name": "NBNE CRM",
  "description": "B2B project management and business development platform — Deek-connected with semantic search, email integration, pipeline analytics",
  "codebase_path": "/app/data/repos/crm",
  "git_repo": "https://github.com/NBNEORIGIN/crm.git",
  "git_branch": "main",
  "project_type": "coding",
  "force_model": "api",

  "permissions": [
    "read_file",
    "search_code",
    "edit_file",
    "create_file",
    "run_tests",
    "run_command",
    "run_migration",
    "check_server",
    "git_status",
    "git_diff",
    "git_log",
    "git_add",
    "git_commit",
    "git_push",
    "git_branch",
    "git_stash",
    "web_fetch",
    "web_check_status",
    "search_crm",
    "write_crm_memory",
    "mark_crm_actioned",
    "set_crm_project_folder",
    "get_quote_context",
    "search_similar_quotes",
    "review_quote_draft",
    "write_wiki",
    "search_wiki",
    "search_emails",
    "get_module_snapshot",
    "retrieve_similar_decisions"
  ],

  "model_preferences": {
    "force_model": "api",
    "opus_keywords": [
      "architecture", "semantic search", "embedding pipeline",
      "email integration", "GDPR", "cross-module", "Deek context"
    ]
  },

  "related_projects": ["deek", "manufacturing", "phloe"],

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": ["node_modules", ".next", ".vercel"],
    "include_extensions": [".ts", ".tsx", ".js", ".json", ".md", ".sql"]
  }
}

{
  "name": "Render",
  "description": "AI-driven sign product design and marketplace publishing system for NBNE",
  "codebase_path": "/app/data/repos/render",
  "git_repo": "https://github.com/NBNEORIGIN/render.git",
  "git_branch": "main",
  "github": "https://github.com/NBNEORIGIN/render",
  "project_type": "coding",
  "force_model": "api",

  "permissions": [
    "read_file",
    "search_code",
    "run_tests",
    "edit_file",
    "create_file",
    "run_command",
    "check_server",
    "git_status",
    "git_diff",
    "git_log",
    "git_add",
    "git_commit",
    "git_push",
    "git_branch",
    "git_stash",
    "web_fetch",
    "web_check_status",
    "web_search"
  ],

  "model_preferences": {
    "force_model": "api",
    "opus_keywords": [
      "architect", "architecture", "design decision",
      "security", "performance", "trade-off", "approach",
      "pipeline", "marketplace", "template"
    ]
  },

  "indexing": {
    "auto_reindex": true,
    "exclude_paths": ["node_modules", ".venv", "venv", "dist", "__pycache__", "exports"],
    "include_extensions": [".py", ".html", ".js", ".css", ".svg", ".json", ".csv", ".md"]
  },

  "subprojects": []
}

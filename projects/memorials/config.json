{
  "name": "Memorials",
  "description": "Personalised memorial product order processing and SVG print sheet generation",
  "codebase_path": "D:/memorials",
  "github": "https://github.com/NBNEORIGIN/memorials",
  "project_type": "coding",
  "force_model": "api",

  "permissions": [
    "read_file",
    "search_code",
    "run_tests",
    "edit_file",
    "create_file",
    "run_command",
    "check_server",
    "git_status",
    "git_diff",
    "git_log",
    "git_add",
    "git_commit",
    "git_push",
    "git_branch",
    "git_stash"
  ],

  "model_preferences": {
    "force_model": "api",
    "opus_keywords": [
      "architect", "architecture", "design decision",
      "security", "processor", "print sheet", "pipeline"
    ]
  },

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": ["node_modules", ".venv", "venv", "__pycache__", ".next", "uploads", "output", "dist"],
    "include_extensions": [".py", ".tsx", ".ts", ".json", ".md", ".yml", ".css"]
  },

  "subprojects": [],

  "memory_api": {
    "base_url": "http://178.104.1.152:8012",
    "retrieve": "/api/memory/retrieve",
    "write": "/api/memory/write",
    "status": "/api/memory/status"
  },

  "backup": {
    "method": "ark",
    "scripts": ["projects/ark/backup-memorials.sh", "projects/ark/restore-memorials.sh"],
    "volumes": ["memorials-data", "memorials-uploads", "memorials-output"],
    "database": "sqlite"
  }
}

{
  "name": "Origin Designed Manufacturing",
  "description": "Manufacturing management system replacing the Excel/Google Sheets workbook",
  "codebase_path": "C:/path/to/manufacturing/repo",
  "project_type": "coding",

  "permissions": [
    "read_file",
    "search_code",
    "run_tests",
    "edit_file",
    "create_file",
    "run_migration"
  ],

  "model_preferences": {
    "force_model": null,
    "prefer_local_for": ["fix", "add", "update", "test"],
    "prefer_api_for": ["architect", "design", "review", "data model"]
  },

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": ["migrations", "node_modules"],
    "include_extensions": []
  }
}

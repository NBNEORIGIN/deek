{
  "name": "DEEK",
  "description": "DEEK itself — the sovereign AI coding agent platform",
  "codebase_path": "/app",
  "project_type": "coding",
  "force_model": "api",

  "permissions": [
    "read_file",
    "search_code",
    "edit_file",
    "create_file",
    "run_tests",
    "run_command",
    "check_server",
    "git_status",
    "git_diff",
    "git_log",
    "git_add",
    "git_commit",
    "git_push",
    "git_branch",
    "git_stash",
    "web_fetch",
    "web_check_status",
    "web_search",
    "query_amazon_intel",
    "search_crm",
    "write_crm_memory",
    "mark_crm_actioned",
    "set_crm_project_folder",
    "get_quote_context",
    "search_similar_quotes",
    "review_quote_draft",
    "write_wiki",
    "get_module_snapshot",
    "retrieve_similar_decisions",
    "search_wiki",
    "search_emails",
    "analyze_enquiry"
  ],

  "model_preferences": {
    "force_model": "api",
    "opus_keywords": [
      "architect", "architecture", "design decision",
      "security", "performance", "trade-off", "approach"
    ]
  },

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": [".venv", "node_modules", ".next", "__pycache__", "data", "logs"],
    "include_extensions": [".py", ".ts", ".tsx", ".json", ".md"]
  }
}

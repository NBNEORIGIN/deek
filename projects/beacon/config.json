{
  "name": "Beacon",
  "description": "Google Ads conversion upload + campaign observability for NBNE tenants. Django backend, OAuth-connected Google Ads accounts, Celery-scheduled syncs.",
  "codebase_path": "/app/data/repos/beacon",
  "git_repo": "https://github.com/NBNEORIGIN/beacon.git",
  "git_branch": "master",
  "project_type": "coding",
  "force_model": "api",

  "permissions": [
    "read_file",
    "search_code",
    "run_tests",
    "edit_file",
    "create_file",
    "run_migration",
    "run_command",
    "check_server",
    "git_status",
    "git_diff",
    "git_log",
    "git_add",
    "git_commit",
    "git_push",
    "git_branch",
    "git_stash",
    "web_fetch",
    "web_check_status",
    "web_search"
  ],

  "model_preferences": {
    "force_model": "api",
    "opus_keywords": [
      "architect", "architecture", "design decision",
      "security", "performance", "trade-off", "approach",
      "attribution", "conversion", "gaql"
    ]
  },

  "indexing": {
    "auto_reindex": false,
    "exclude_paths": ["node_modules", "migrations", ".next", "dist", "__pycache__", ".venv"],
    "include_extensions": []
  }
}
